{
  "name": "wterm",
  "version": "0.1.3",
  "private": true,
  "description": "Multi-project, multi-terminal workspace IDE",
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "test": "vitest run",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "rebuild": "electron-rebuild -f -w node-pty",
    "postinstall": "electron-rebuild -f -w node-pty || exit 0",
    "build:icons": "node scripts/build-icons.mjs",
    "dist": "npm run build:icons && electron-vite build && electron-builder",
    "dist:mac": "npm run build:icons && electron-vite build && electron-builder --mac",
    "dist:win": "npm run build:icons && electron-vite build && electron-builder --win"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "node-pty",
      "@electron/rebuild",
      "esbuild"
    ]
  },
  "build": {
    "appId": "com.ddnazzah.wterm",
    "productName": "wTerm",
    "asar": true,
    "asarUnpack": [
      "**/node_modules/node-pty/**"
    ],
    "files": [
      "out/**/*",
      "package.json",
      "!**/*.map"
    ],
    "directories": {
      "buildResources": "resources",
      "output": "release/${version}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "ddnazzah",
        "repo": "wTerm"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "notarize": true,
      "artifactName": "wTerm-${version}-${arch}.${ext}"
    },
    "dmg": {
      "writeUpdateInfo": false
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "wTerm-${version}-${arch}-setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "differentialPackage": false
    },
    "npmRebuild": false
  },
  "dependencies": {
    "@heroui/react": "^3.0.5",
    "@heroui/styles": "^3.0.5",
    "@vscode/codicons": "^0.0.45",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "electron-updater": "^6.8.9",
    "material-icon-theme": "^5.35.0",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.1.0",
    "prettier": "^3.8.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-variants": "^3.2.2",
    "uuid": "^14.0.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "playwright": "^1.61.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.3",
    "vitest": "^4.1.9"
  }
}
